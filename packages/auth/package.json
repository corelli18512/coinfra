{
  "name": "@coinfra/auth",
  "version": "0.2.0",
  "description": "The sign-in wheel: Better Auth extended with domestic-China connectors (WeChat, WeCom, SMS OTP) and a coinfra house preset. Embedded library — each app runs it in-process, no standalone identity server.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wechat": {
      "types": "./dist/wechat.d.ts",
      "import": "./dist/wechat.js"
    },
    "./wecom": {
      "types": "./dist/wecom.d.ts",
      "import": "./dist/wecom.js"
    },
    "./alipay": {
      "types": "./dist/alipay.d.ts",
      "import": "./dist/alipay.js"
    },
    "./qq": {
      "types": "./dist/qq.d.ts",
      "import": "./dist/qq.js"
    },
    "./weibo": {
      "types": "./dist/weibo.d.ts",
      "import": "./dist/weibo.js"
    },
    "./douyin": {
      "types": "./dist/douyin.d.ts",
      "import": "./dist/douyin.js"
    },
    "./dingtalk": {
      "types": "./dist/dingtalk.d.ts",
      "import": "./dist/dingtalk.js"
    },
    "./feishu": {
      "types": "./dist/feishu.d.ts",
      "import": "./dist/feishu.js"
    },
    "./sms": {
      "types": "./dist/sms.d.ts",
      "import": "./dist/sms.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "better-auth": ">=1.6.0 <2"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/memory-adapter": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "better-auth": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corelli18512/coinfra.git",
    "directory": "packages/auth"
  }
}
