{
  "name": "@coinfra/pulse",
  "version": "0.1.2",
  "description": "The delivery contract: message sequencing, acks, and cursor-based resume for a breakable WebSocket channel. Pure logic, no I/O. Each client provides its own transport and storage.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "fast-check": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "ws": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corelli18512/coinfra.git",
    "directory": "packages/pulse"
  }
}
